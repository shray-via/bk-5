generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  category    String
  description String
  year        Int
  pages       Int
  coverColor  String
  createdAt   DateTime @default(now())
}
